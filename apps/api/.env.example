APP_ENV=development
APP_DEBUG=true
FRONTEND_BASE_URL=http://127.0.0.1:5173
DATABASE_URL=sqlite+aiosqlite:///./knowledge_assistant.db
DOCUMENTS_STORAGE_DIRECTORY=storage/documents
CHROMA_STORAGE_DIRECTORY=storage/chroma
MAIL_OUTBOX_DIRECTORY=storage/mail_outbox
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Use a long random value in every non-local environment.
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ACCOUNT_ACTION_TOKEN_EXPIRE_MINUTES=30

# auto => Lax locally, None+Secure in production.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=auto
# AUTH_COOKIE_DOMAIN=

LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# outbox writes .eml files to storage/mail_outbox.
# smtp uses the SMTP settings below.
MAIL_DELIVERY_MODE=outbox
MAIL_FROM_ADDRESS=no-reply@knowledge-ai.local
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
